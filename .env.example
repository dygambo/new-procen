# Environment Variables
# Copy this file to .env and fill in the values before running the app.

# ── Database ──────────────────────────────────────────────────────────────────
# Full PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Session ───────────────────────────────────────────────────────────────────
# A long, random string used to sign session cookies (required in production)
SESSION_SECRET=replace-me-with-a-long-random-string

# ── Runtime ───────────────────────────────────────────────────────────────────
# Set to "production" on Hostinger
NODE_ENV=production

# Port the server listens on.
# Hostinger injects this automatically; override only if running locally.
# PORT=3000
